# MoneyWise pre-commit hook
# Runs essential checks before allowing commit

# Load nvm if available (fixes PATH for pnpm in non-interactive shells)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

echo "🔍 Running pre-commit checks..."

# Documentation governance (auto-fix)
echo "  📋 Documentation governance..."
./.claude/scripts/auto-fix-doc-governance.sh || {
  echo "❌ Documentation governance check failed."
  exit 1
}

# Check if Prisma Client is generated (backend only)
if [ -d "apps/backend" ] && [ ! -d "apps/backend/generated/prisma" ]; then
  echo "  ⚠️  Prisma Client not generated. Generating now..."
  cd apps/backend && pnpm prisma:generate && cd ../.. || {
    echo "❌ Prisma Client generation failed."
    exit 1
  }
  echo "  ✅ Prisma Client generated"
fi

# Check GitHub Actions workflows if any are staged
echo "  🔍 Checking GitHub Actions workflows..."
if git diff --cached --name-only | grep -q "^\.github/workflows/"; then
  echo "    📋 Workflow files detected in this commit"

  # Try to validate with actionlint
  ACTIONLINT_PATH="./.claude/tools/actionlint"

  if [ -x "$ACTIONLINT_PATH" ]; then
    echo "    📍 Validating with actionlint..."
    if "$ACTIONLINT_PATH" -color .github/workflows/*.yml > /dev/null 2>&1; then
      echo "    ✅ GitHub Actions workflows are valid"
    else
      echo "    ❌ GitHub Actions workflows have errors:"
      "$ACTIONLINT_PATH" -color .github/workflows/*.yml || true
      echo ""
      echo "❌ Please fix workflow errors before committing."
      exit 1
    fi
  else
    echo "    ⚠️  actionlint not found, skipping detailed workflow validation"
    echo "    💡 Install with: pnpm setup:actionlint"
  fi
else
  echo "    ⏭️  No workflow files in this commit"
fi

echo ""

# Run linting
echo "  ✨ Linting..."
pnpm lint || {
  echo "❌ Linting failed. Please fix errors and try again."
  exit 1
}

# Run type checking
echo "  🔍 Type checking..."
pnpm typecheck || {
  echo "❌ Type checking failed. Please fix errors and try again."
  exit 1
}

# Run unit tests (fast)
echo "  🧪 Running unit tests..."
pnpm test:unit || {
  echo "❌ Unit tests failed. Please fix failing tests and try again."
  exit 1
}

echo "✅ Pre-commit checks passed!"