# MoneyWise pre-commit hook — scope-aware
# Runs only the checks relevant to the staged scope, so Supabase/SQL-only
# commits don't need node_modules and Deno-only work isn't gated by jsdom.

# Load nvm if available (fixes PATH for pnpm in non-interactive shells)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

echo "🔍 Running pre-commit checks..."

STAGED=$(git diff --cached --name-only)

# Always: documentation governance (auto-fix)
echo "  📋 Documentation governance..."
./.claude/scripts/auto-fix-doc-governance.sh || {
  echo "❌ Documentation governance check failed."
  exit 1
}

# Actionlint on staged workflows
echo "  🔍 Checking GitHub Actions workflows..."
if echo "$STAGED" | grep -q "^\.github/workflows/"; then
  echo "    📋 Workflow files detected in this commit"
  ACTIONLINT_PATH="./.claude/tools/actionlint"
  if [ -x "$ACTIONLINT_PATH" ]; then
    if "$ACTIONLINT_PATH" -color .github/workflows/*.yml > /dev/null 2>&1; then
      echo "    ✅ GitHub Actions workflows are valid"
    else
      echo "    ❌ GitHub Actions workflows have errors:"
      "$ACTIONLINT_PATH" -color .github/workflows/*.yml || true
      echo ""
      echo "❌ Please fix workflow errors before committing."
      exit 1
    fi
  else
    echo "    ⚠️  actionlint not found, skipping detailed workflow validation"
    echo "    💡 Install with: pnpm setup:actionlint"
  fi
else
  echo "    ⏭️  No workflow files in this commit"
fi

echo ""

# Scope detection
NEEDS_PNPM=false
if echo "$STAGED" | grep -qE '^(apps/web|packages)/'; then
  NEEDS_PNPM=true
fi

# Sprint 1.6 #011: root dependency-management changes must trigger full pnpm gate.
# Include root package.json updates to `overrides`, `workspaces`, or `pnpm` keys
# + pnpm-workspace.yaml changes — affettano dependency resolution monorepo-wide.
# Meta-lesson Dependabot batch 2026-04-20: root `pnpm.overrides` precede workspace
# deps, quindi bump richiede test full (TS2742 osservato su override @types/react).
# Regex stretto a JSON key syntax `"overrides":` per evitare match su script lines
# che contengono la parola "pnpm" (es. `"test": "pnpm run test"`).
if echo "$STAGED" | grep -q '^package\.json$'; then
  if git diff --cached -- package.json | grep -qE '^[+-][[:space:]]*"(overrides|workspaces|pnpm)"[[:space:]]*:'; then
    NEEDS_PNPM=true
    echo "  📦 Root package.json overrides/workspaces/pnpm key change → full pnpm gate"
  fi
fi

if echo "$STAGED" | grep -q '^pnpm-workspace\.yaml$'; then
  NEEDS_PNPM=true
  echo "  📦 pnpm-workspace.yaml change → full pnpm gate"
fi

TOUCHES_FUNCTIONS=false
if echo "$STAGED" | grep -q '^supabase/functions/'; then
  TOUCHES_FUNCTIONS=true
fi

if [ "$NEEDS_PNPM" = "true" ]; then
  if [ ! -d node_modules ]; then
    echo "❌ node_modules missing in this worktree. Run: pnpm install"
    exit 1
  fi

  echo "  ✨ Linting..."
  pnpm lint || {
    echo "❌ Linting failed. Please fix errors and try again."
    exit 1
  }

  echo "  🔍 Type checking..."
  pnpm typecheck || {
    echo "❌ Type checking failed. Please fix errors and try again."
    exit 1
  }

  # Node 24+ breaks vitest+jsdom (React is not defined). CI validates web tests.
  NODE_MAJOR=$(node -p 'process.versions.node.split(".")[0]')
  if [ "$NODE_MAJOR" -le "22" ]; then
    echo "  🧪 Running unit tests..."
    pnpm test:unit || {
      echo "❌ Unit tests failed. Please fix failing tests and try again."
      exit 1
    }
  else
    echo "  ⏭️  Skipping jsdom tests (Node $NODE_MAJOR incompatible). CI validates."
  fi
else
  echo "  ⏭️  No web/packages changes — skipping pnpm lint/typecheck/test"
fi

if [ "$TOUCHES_FUNCTIONS" = "true" ]; then
  if command -v deno >/dev/null 2>&1; then
    echo "  🦕 Deno lint (supabase/functions)..."
    deno lint supabase/functions || {
      echo "⚠️ deno lint reported issues (CI is the blocking gate)"
    }
  else
    echo "  ⚠️  deno not installed locally — CI will run the blocking deno test gate"
  fi
fi

echo "✅ Pre-commit checks passed!"
