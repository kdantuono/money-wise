# ===========================================================================
# ⚠️  WARNING: TEST ENVIRONMENT ONLY - NEVER USE IN PRODUCTION
# ===========================================================================
#
# This file contains TEST-ONLY configuration for E2E automated testing.
#
# 🔒 SECURITY NOTICE:
# - These credentials are INTENTIONALLY WEAK for local testing purposes
# - DO NOT copy these values to any production environment
# - DO NOT use these passwords for any real accounts or systems
# - DO NOT commit real secrets or production credentials to this file
# - These values are designed for throwaway test databases and local-only use
#
# For production environments:
# - Use strong, randomly generated secrets (minimum 32 characters)
# - Store secrets in secure secret management systems (e.g., AWS Secrets Manager, Vault)
# - Use environment-specific .env files that are NEVER committed to git
# - Enable secret rotation and monitoring
#
# ===========================================================================

# Application URLs
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Supabase Configuration (required for E2E tests)
# These keys are intentionally present but empty by default so missing values
# fail as explicit configuration issues rather than silent runtime errors.
# Populate via local uncommitted overrides or CI/workflow env secrets before running E2E tests.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Test Configuration
NODE_ENV=test
CI=false
DEBUG=false

# Timeouts
TEST_TIMEOUT=30000
API_TIMEOUT=10000

# Test User Credentials (default test user - clearly marked as test-only)
TEST_USER_EMAIL=e2e.test.user@moneywise.test
TEST_USER_PASSWORD=E2E_Test_Pass_2025!

# Banking Integration (Test Mode)
SALT_EDGE_APP_ID=test-app-id
SALT_EDGE_SECRET=test-secret
SALT_EDGE_BASE_URL=https://www.saltedge.com/api/v5
SALT_EDGE_MODE=test

# Email (Mock for testing)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
EMAIL_FROM=noreply@moneywise.test

# Feature Flags
ENABLE_BANKING=true
ENABLE_BUDGETS=true
ENABLE_REPORTS=true
ENABLE_NOTIFICATIONS=false

# Logging
LOG_LEVEL=error
LOG_TO_FILE=false

# Playwright Specific
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=0

# Headless Mode
HEADLESS=true

# Screenshots and Videos
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_FAILURE=true
